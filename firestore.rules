rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /properties/{propertyId} {
      allow read, write: if true;
    }

    match /weightRecords/{weightRecordId} {
      allow read, write: if true;
    }

    match /appState/{stateId} {
      allow read, write: if true;
    }
  }
}
